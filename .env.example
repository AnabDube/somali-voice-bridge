VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Edge function secrets (set via: supabase secrets set KEY=value)
# ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:8080
# GROQ_API_KEY=your-groq-api-key  (used by translate-text)

# Azure OpenAI — used by transcribe-audio for Whisper
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-openai-key
# AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper
# AZURE_OPENAI_API_VERSION=2024-06-01
